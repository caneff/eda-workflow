<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>EDA Workflow Report</title>
  <style>
    :root {
      color-scheme: light;
      --bg: #f6f8fb;
      --surface: #ffffff;
      --surface-soft: #eef6f3;
      --ink: #17202a;
      --muted: #5f6f7f;
      --accent: #0f766e;
      --accent-soft: #dff4ef;
      --border: #d7e0e8;
      --code-bg: #14213d;
      --code-ink: #f7fbff;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      background: var(--bg);
      color: var(--ink);
      font-family:
        Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
        "Segoe UI", sans-serif;
      line-height: 1.5;
    }

    a {
      color: var(--accent);
      font-weight: 650;
    }

    .report {
      width: min(1120px, calc(100% - 32px));
      margin: 0 auto;
      padding: 32px 0 56px;
    }

    .hero,
    .section {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      box-shadow: 0 10px 30px rgb(20 33 61 / 8%);
    }

    .hero {
      padding: 32px;
    }

    .eyebrow {
      margin: 0 0 8px;
      color: var(--accent);
      font-size: 0.78rem;
      font-weight: 750;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    h1,
    h2,
    h3 {
      margin: 0;
      line-height: 1.15;
    }

    h1 {
      font-size: 2.2rem;
    }

    h2 {
      font-size: 1.45rem;
    }

    h3 {
      color: var(--muted);
      font-size: 0.82rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .metadata {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 12px;
      margin: 28px 0 0;
    }

    .metadata-item {
      padding: 14px 16px;
      background: var(--surface-soft);
      border: 1px solid var(--accent-soft);
      border-radius: 8px;
    }

    .metadata dt {
      color: var(--muted);
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: uppercase;
    }

    .metadata dd {
      margin: 4px 0 0;
    }

    .section {
      margin-top: 18px;
      overflow: hidden;
    }

    .section-header {
      padding: 22px 24px;
      border-bottom: 1px solid var(--border);
    }

    .section-grid,
    .synthesis {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(280px, 0.42fr);
    }

    .panel {
      padding: 24px;
    }

    .panel + .panel {
      border-left: 1px solid var(--border);
    }

    .scalar-table {
      width: 100%;
      margin-top: 16px;
      border-collapse: collapse;
    }

    .scalar-table th,
    .scalar-table td {
      padding: 10px 12px;
      border-bottom: 1px solid var(--border);
      text-align: left;
      vertical-align: top;
    }

    .scalar-table th {
      color: var(--muted);
      font-size: 0.78rem;
      text-transform: uppercase;
    }

    details {
      margin-top: 14px;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: #fbfdff;
      overflow: hidden;
    }

    summary {
      cursor: pointer;
      padding: 12px 14px;
      color: var(--accent);
      font-weight: 700;
    }

    pre {
      margin: 0;
      padding: 16px;
      overflow-x: auto;
      background: var(--code-bg);
      color: var(--code-ink);
    }

    code {
      font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
      font-size: 0.9rem;
    }

    .empty {
      color: var(--muted);
      font-style: italic;
    }

    .list {
      margin: 16px 0 0;
      padding-left: 20px;
    }

    .list li + li {
      margin-top: 8px;
    }

    @media (max-width: 760px) {
      .hero {
        padding: 24px;
      }

      .section-grid,
      .synthesis {
        grid-template-columns: 1fr;
      }

      .panel + .panel {
        border-top: 1px solid var(--border);
        border-left: 0;
      }
    }
  </style>
</head>
<body>
  <main class="report">
    <header class="hero">
      <p class="eyebrow">Exploratory Data Analysis</p>
      <h1>EDA Workflow Report</h1>
      {% if metadata %}
      <dl class="metadata">
        {% for item in metadata %}
        <div class="metadata-item">
          <dt>{{ item.label }}</dt>
          <dd>
            {% if item.href %}
            <a href="{{ item.href }}"><code>{{ item.value }}</code></a>
            {% else %}
            <code>{{ item.value }}</code>
            {% endif %}
          </dd>
        </div>
        {% endfor %}
      </dl>
      {% endif %}
    </header>

    {% for step in steps %}
    <section class="section">
      <div class="section-header">
        <h2>{{ step.title }}</h2>
      </div>
      <div class="section-grid">
        <div class="panel">
          <h3>Results</h3>
          {% if step.has_results %}
          {% if step.scalar_results %}
          <table class="scalar-table">
            <thead>
              <tr>
                <th>Field</th>
                <th>Value</th>
              </tr>
            </thead>
            <tbody>
              {% for row in step.scalar_results %}
              <tr>
                <td><code>{{ row.key }}</code></td>
                <td><code>{{ row.value }}</code></td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
          {% endif %}

          {% for item in step.nested_results %}
          <details>
            <summary><code>{{ item.key }}</code> ({{ item.type }}, {{ item.count }} items)</summary>
            <pre><code>{{ item.json }}</code></pre>
          </details>
          {% endfor %}
          {% else %}
          <p class="empty">No results.</p>
          {% endif %}
        </div>
        <div class="panel">
          <h3>Observations</h3>
          {% if step.observations %}
          <ul class="list">
            {% for observation in step.observations %}
            <li>{{ observation }}</li>
            {% endfor %}
          </ul>
          {% else %}
          <p class="empty">No observations.</p>
          {% endif %}
        </div>
      </div>
    </section>
    {% endfor %}

    <section class="section">
      <div class="section-header">
        <h2>Final Synthesis</h2>
      </div>
      <div class="synthesis">
        <div class="panel">
          <h3>Summary</h3>
          {% if summary %}
          <p>{{ summary }}</p>
          {% else %}
          <p class="empty">No summary.</p>
          {% endif %}
        </div>
        <div class="panel">
          <h3>Recommendations</h3>
          {% if recommendations %}
          <ul class="list">
            {% for recommendation in recommendations %}
            <li>{{ recommendation }}</li>
            {% endfor %}
          </ul>
          {% else %}
          <p class="empty">No recommendations.</p>
          {% endif %}
        </div>
      </div>
    </section>
  </main>
</body>
</html>
